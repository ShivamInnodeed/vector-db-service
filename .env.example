# VectorDB Service – configuration via environment variables
# Copy to .env and set values. The module reads these at runtime (no code changes).

# Elasticsearch URL (required)
# Local:  http://localhost:9200
# Deployed: set to your hosted ES (e.g. AWS OpenSearch, Elastic Cloud)
ELASTICSEARCH_URL=http://localhost:9200

# Optional
ELASTICSEARCH_INDEX_PREFIX=vectordb
VECTOR_DIMENSION=384
ELASTICSEARCH_TIMEOUT=30
ELASTICSEARCH_MAX_RETRIES=3
ENABLE_TELEMETRY=true
# OTLP_ENDPOINT=http://your-otel-endpoint:4317
